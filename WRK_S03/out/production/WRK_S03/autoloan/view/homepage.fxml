<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER"
      prefWidth="1400.0"
      prefHeight="900.0"
      spacing="45"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="autoloan.controller.HomepageController">

    <padding>
        <Insets top="60" bottom="60"/>
    </padding>

    <Label text="AUTO LOAN MANAGEMENT SYSTEM"
           style="-fx-font-size:36px; -fx-font-weight:bold;"/>

    <Label text="Welcome to the Auto Loan Application Portal"
           style="-fx-font-size:18px;"/>

    <HBox alignment="CENTER" spacing="20">
        <Button text="Go to Login"
                prefWidth="220"
                prefHeight="50"
                style="-fx-font-size:16px;"
                onAction="#openLogin"/>

        <Button text="Go to Signup"
                prefWidth="220"
                prefHeight="50"
                style="-fx-font-size:16px;"
                onAction="#openSignup"/>
    </HBox>

</VBox>
