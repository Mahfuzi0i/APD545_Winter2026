<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="autoloan.controller.SignupController">

    <center>
        <VBox alignment="CENTER" spacing="30">

            <!-- Title -->
            <Label style="-fx-font-size:28px; -fx-font-weight:bold;" text="CREATE NEW ACCOUNT" />

            <!-- Form Container -->
            <VBox alignment="CENTER" spacing="18">

                <!-- Username -->
                <HBox alignment="CENTER" spacing="15">
                    <Label prefWidth="150" text="Username:" />
                    <TextField fx:id="usernameField" prefHeight="40.0" prefWidth="280" promptText="exampleUser" />
                </HBox>

                <!-- Email -->
                <HBox alignment="CENTER" spacing="15">
                    <Label prefWidth="150" text="Email:" />
                    <TextField fx:id="emailField" prefHeight="37.0" prefWidth="280" promptText="email@example.com" />
                </HBox>

                <!-- Password -->
                <HBox alignment="CENTER" spacing="15">
                    <Label prefWidth="150" text="Password:" />
                    <PasswordField fx:id="passwordField" prefHeight="39.0" prefWidth="280" promptText="password" />
                </HBox>

                <!-- Confirm Password -->
                <HBox alignment="CENTER" spacing="15">
                    <Label prefWidth="150" text="Confirm Password:" />
                    <PasswordField fx:id="confirmField" prefHeight="39.0" prefWidth="280" promptText="confirm password" />
                </HBox>

            </VBox>

            <!-- Buttons -->
            <HBox alignment="CENTER" spacing="25">
                <Button onAction="#handleSignup" prefHeight="40" prefWidth="180" text="Create Account" />

                <Button onAction="#backToLogin" prefHeight="40" prefWidth="180" text="Back to Login" />
            </HBox>

            <!-- Message -->
            <Label fx:id="messageLabel" style="-fx-font-size:14px;" textFill="red" />

        </VBox>
    </center>

</BorderPane>

